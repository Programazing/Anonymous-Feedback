PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=http://anonymous-feedback-fghjfghjfghsdfg-grlpi-b3c6cc-31-97-103-251.sslip.io
PUBLIC_PATH=/f/a67e5d75c0faac74070b5b62
ADMIN_PATH=/r/7dcd8ee0cf3f015179b88871
ADMIN_TOKEN=cb373fb438bd2ab80b9041b6422eb72811ab6e09e233b996942bb92687e65e3a
# LOG_PUBLIC_URL controls whether the full public feedback URL (including the
# randomized PUBLIC_PATH) is printed to stdout at startup. When unset it
# defaults to false in production (NODE_ENV=production) and true otherwise.
# Set to true temporarily on a production host if you need the URL echoed for
# debugging, then unset it and restart. LOG_ADMIN_URL is no longer supported:
# the admin URL is never printed to logs. Read ADMIN_PATH from this file
# directly on the host to obtain it.
LOG_PUBLIC_URL=false
DB_PATH=/app/data/feedback.sqlite
# Optional diagnostic routes. Keep BOTH set to false in production.
# ENABLE_HEALTHCHECK: exposes GET /healthz which returns {"ok":true} with no
#   auth and no secrets. Enable it only if the container orchestrator (Docker
#   Compose healthcheck, Kubernetes probe, etc.) needs to poll it. Do NOT
#   route /healthz through the public reverse proxy unless you also add an
#   IP allowlist — container-internal probes reach it without a public route.
ENABLE_HEALTHCHECK=false
# ENABLE_DEBUG_ROUTES: exposes GET /debug/routes. Even when enabled it
#   REQUIRES the ADMIN_TOKEN (x-admin-token header) and its response omits
#   PUBLIC_PATH, ADMIN_PATH, ADMIN_TOKEN, process.env, and DB contents.
#   Intended for short-lived debugging on a scratch instance only.
ENABLE_DEBUG_ROUTES=false